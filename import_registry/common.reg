    "Order"=dword:20

[HKEY_LOCAL_MACHINE\Comm\ConnMgr\CSPRAS\ConnectionTypes]
; The values under this key are the connection types that CSPRAS will be
; used to configure and manage. Each value is of the format:
;    "<UniqueName>"=hex:<Connection Type GUID>
;
; CM_CSP_RAS_TYPE:
"{59B09E94-9E0E-456b-A02B-F73AED543130}"=hex:94,9E,B0,59, 0E,9E, 6B,45, A0,2B,F7,3A,ED,54,31,30

IF IMGNDISGPRS !
; CM_CSP_GSM_PACKET_TYPE
"{A05DC613-E393-40ad-AA89-CCCE04277CD9}"=hex:13,C6,5D,A0, 93,E3, AD,40, AA,89,CC,CE,04,27,7C,D9
ENDIF

IF IMGNDISGPRS !
; The values under this key are used by CSPRAS to to associate Resource Manager Resource IDs
; to specific RAS connections. Each value is of the format:
; [HKEY_LOCAL_MACHINE\Comm\ConnMgr\CSPRAS\ResourceIds\<ConnectionType GUID String>]
;   "<DeviceName>=hex:<ResourceId GUID>
;
; Associate RAS Type connections (CDMA) to the Cellular packet RM resource ID:
; CM_CSP_RAS_TYPE {59B09E94-9E0E-456b-A02B-F73AED543130} "Cellular Line"
;  to RM_GSM_PACKET_RESOURCE_ID {1D0A197C-B982-4791-BFC1-D8E4B156E0B7}
;
[HKEY_LOCAL_MACHINE\Comm\ConnMgr\CSPRAS\ResourceIds\{59B09E94-9E0E-456b-A02B-F73AED543130}]
"Cellular Line"=hex:7C,19,0A,1D, 82,B9, 91,47, BF,C1,D8,E4,B1,56,E0,B7

; Associate GSM/UMTS PPP data connections to the Cellular packet RM resource ID:
; CM_CSP_GSM_PACKET_TYPE {A05DC613-E393-40ad-AA89-CCCE04277CD9} "Cellular Line"
;  to RM_GSM_PACKET_RESOURCE_ID {1D0A197C-B982-4791-BFC1-D8E4B156E0B7}
;
[HKEY_LOCAL_MACHINE\Comm\ConnMgr\CSPRAS\ResourceIds\{A05DC613-E393-40ad-AA89-CCCE04277CD9}]
"Cellular Line"=hex:7C,19,0A,1D, 82,B9, 91,47, BF,C1,D8,E4,B1,56,E0,B7

; Set RSPCellular RAS based behavior for all non-NDIS GPRS configurations
; including PPP/RAS and CDMA devices.
;
[HKEY_LOCAL_MACHINE\Comm\ConnMgr\ResMgr\Providers\RspCellular]
"RasSupport"=dword:1
ENDIF

; @CESYSGEN ENDIF


; @CESYSGEN IF CE_MODULES_CMCSPIP
[HKEY_LOCAL_MACHINE\Comm\Connmgr\CspsToLoad\CmCspIp]
    "Dll"="CmCspIp.dll"
    "Order"=dword:100
; @CESYSGEN ENDIF

; @CESYSGEN IF CE_MODULES_RMNET
;
; Resource Manager Application Conflict Policy settings
; 
; Entries in this key take the form of:
; "sid_string:Interactive|Background " = DWORD:PriorityOrder
;
; Where sid_string is the unique account name identifying an
; application.
;
; Interactive/Background is determined from the priority 
; value passed into RM from Connection Manager. This
; value can be changed by a CM client through CmSetPriority.
; Background values are considered in the range: 0 - 2^16-1
; Interactive values are considered in the range: 2^16 - 2^32-1
;
; PriorityOrder is the ordered value of the applications
; in the policy. Higher PriorityOrder values result in a 
; lower order position.
;
; For example, in the configuration below, MobileVPN is 
; higher priority than the default values.
; 
[HKEY_LOCAL_MACHINE\Comm\ConnMgr\ResMgr\Policy]
; Default values assigned to applications not listed in the AppConflict Policy    
    "Default:Interactive"=dword:100
    "Default:Background"=dword:160

; MobileVPN: S-1-5-112-0-0X11-0X00000002
    "S-1-5-112-0-0X11-0X00000002:Interactive"=dword:20
    "S-1-5-112-0-0X11-0X00000002:Background"=dword:40

; Outlook: S-1-5-112-0-0X10-0X00000006
    "S-1-5-112-0-0X10-0X00000006:Interactive"=dword:60
    "S-1-5-112-0-0X10-0X00000006:background"=dword:120

; IE: S-1-5-112-0-0X20-0X0000000F
    "S-1-5-112-0-0X20-0X0000000F:Interactive"=dword:80
    "S-1-5-112-0-0X20-0X0000000F:background"=dword:140
; @CESYSGEN ENDIF


