IF BSP_NOETHER !
IF BSP_NIC_E100BEX

[HKEY_LOCAL_MACHINE\Comm\e100bex]
   "DisplayName"="Intel 82559"
   "Group"="NDIS"
   "ImagePath"="E100BEX.dll"

[HKEY_LOCAL_MACHINE\Drivers\BuiltIn\PCI\Template\E100BEX]
   "Dll"="NDIS.dll"
   "Class"=dword:02
   "SubClass"=dword:00
   "ProgIF"=dword:0
   "VendorID"=multi_sz:"8086"
   "DeviceID"=multi_sz:"1229"
   "Prefix"="NDS"
   ; Flags==2 is DEVFLAGS_LOADLIBRARY
   "Flags"=dword:2

;
; Use standard GIISR for Interrupt Service Routine.
;
   "IsrDll"="giisr.dll"
   "IsrHandler"="ISRHandler"

   "PortIsIO"=dword:1
   "PortOffset"=dword:0
   "PortSize"=dword:2
   "PortMask"=dword:F300

   ; IF_TYPE_ETHERNET_CSMACD
   "*IfType"=dword:6
   ; NdisMedium802_3
   "*MediaType"=dword:0
   ; NdisPhysicalMediumUnspecified
   "*PhysicalMediaType"=dword:0

[HKEY_LOCAL_MACHINE\Comm\PCI\E100BEX1\Parms\Tcpip]
    "EnableWINS"=dword:1

ENDIF BSP_NIC_E100BEX
ENDIF BSP_NOETHER !
ENDIF BSP_NOPCIBUS !
