; @CESYSGEN IF FILESYS_FSREGHIVE
; HIVE BOOT SECTION

; Valid Bits for Flags registry value
; If no flags are set, the hive will be stored in the object store.
;
; 0x00000001    Start storage manager in boot phase 1 for hive-based registry
; 0x00000002    Start device manager in boot phase 1 for hive-based registry
; 0x00000004    Start storage manager in boot phase 1 for registry in
;               external ROM (such as BINFS)
; 0x00000008    Start device manager in boot phase 1 for registry in
;               external ROM (such as BINFS)

[HKEY_LOCAL_MACHINE\init\BootVars]
   "SystemHive"="Windows\\Registry\\system.hv"
   "ProfileDir"="Windows\\Registry"
   "Flags"=dword:1
; END HIVE BOOT SECTION
; @CESYSGEN ENDIF FILESYS_FSREGHIVE

; @CESYSGEN IF FILESYS_FSDBASE
; HIVE BOOT SECTION

; When a bootable persistent storage device is mounted, redirect ObjectStore
; database operations to a volume file on the device. This will be the same
; storage device where the registry hives are stored on FSREGHIVE builds.
[HKEY_LOCAL_MACHINE\System\ObjectStore]
    "DefaultDBVol"="Windows\\Registry\\default.vol"

; END HIVE BOOT SECTION
; @CESYSGEN ENDIF

; HIVE BOOT SECTION
; This key allows untrusted processes (when using 2 tier trust model) to access system files for read.
[HKEY_LOCAL_MACHINE\System\ObjectStore]
    "AllowSystemAccess"=dword:1
; END HIVE BOOT SECTION

;@CESYSGEN IF FILESYS_FSEVENTLOG
[HKEY_LOCAL_MACHINE\System\EventLog\Channel\System]
    "ChannelType"=dword:1
    "Value"=dword:8
    "DefaultEnable"=dword:1

[HKEY_LOCAL_MACHINE\System\EventLog\Channel\System\Logging]
    "MaxSize"=dword:100000
    "Level"=dword:1
    "AllKeywordHigh"=dword:0
    "AllKeywordLow"=dword:0
    "AnyKeywordHigh"=dword:0
    "AnyKeywordLow"=dword:0
    "Latency"=dword:2

[HKEY_LOCAL_MACHINE\System\EventLog\Channel\System\Publishing]
    "ClockType"=dword:0
    "MaxBuffers"=dword:4000

[HKEY_LOCAL_MACHINE\System\EventLog\Channel\Security]
    "ChannelType"=dword:1
    "Value"=dword:a
    "DefaultEnable"=dword:1

[HKEY_LOCAL_MACHINE\System\EventLog\Channel\Security\Logging]
    "MaxSize"=dword:100000
    "Level"=dword:1
    "AllKeywordHigh"=dword:0
    "AllKeywordLow"=dword:0
    "AnyKeywordHigh"=dword:0
    "AnyKeywordLow"=dword:0
    "Latency"=dword:2

[HKEY_LOCAL_MACHINE\System\EventLog\Channel\Security\Publishing]
    "ClockType"=dword:0
    "MaxBuffers"=dword:4000

[HKEY_LOCAL_MACHINE\System\EventLog\Channel\Application]
    "ChannelType"=dword:1
    "Value"=dword:9
    "DefaultEnable"=dword:1

[HKEY_LOCAL_MACHINE\System\EventLog\Channel\Application\Logging]
    "MaxSize"=dword:100000
    "Level"=dword:1
    "AllKeywordHigh"=dword:0
    "AllKeywordLow"=dword:0
    "AnyKeywordHigh"=dword:0
    "AnyKeywordLow"=dword:0
    "Latency"=dword:2

[HKEY_LOCAL_MACHINE\System\EventLog\Channel\Application\Publishing]
    "ClockType"=dword:0
    "MaxBuffers"=dword:4000

;@CESYSGEN ENDIF FILESYS_FSEVENTLOG

;@CESYSGEN IF FILESYS_FSPROFILE
; Configure DPAPI to use AES128 instead of RC4
[HKEY_LOCAL_MACHINE\Comm\Security\DPAPI]
    "Algorithm"=dword:1

; Configure Entropy Pool Parameters
[HKEY_LOCAL_MACHINE\Comm\Security\Crypto]
    "EntropyFromKeypress"=dword:1f4         ; 500 millibits of entropy per keypress
    "EntropyFromTouchEvent"=dword:1f4       ; 500 millibits of entropy per touch event
    "EntropyFromRadioEvent"=dword:3e8       ; 1000 millibits of entropy per radio event
    "EntropyFromTouchDownEvent"=dword:3e8   ; 1000 millibits of entropy per touch down event

;@CESYSGEN ENDIF FILESYS_FSPROFILE

; Replication Filter Registry Map
;
; ReplStoreHostVolume  : Host volume of replication database volume; "" for root, "\\<mount point>" for non-root, e.g., "\\Hard Disk"
; ReplStorePath        : Path of replication database volume on host volume
; ReplStoreName        : Name of replication database in replication database volume
; ReplStoreDoImmaculate: [Optional] Whether to synchronize the replication database to the replicated volume on initialization
; ReplStoreCacheSize   : [Optional] Number of replication records (paths) to cache
; NumDirsToExclude     : [Optional; Required if DirsToExclude present] Number of entries in DirsToExclude
; DirsToExclude        : [Optional; Required if NumDirsToExclude present] Set of fully qualified paths to exclude from replication
;                        e.g., "\\foo\\","\\bar\\" Note that, it is important to include the trailing slash
;
; ReplStoreHostVolume, ReplStorePath, and ReplStoreName must all be defined in order to override the
; default of ("", "\\ReplStorVol", "ReplStor").
;
; HIVE BOOT SECTION
; @CESYSGEN IF CE_MODULES_FSREPLXFILT
; @CESYSGEN ENDIF CE_MODULES_FSREPLXFILT
; END HIVE BOOT SECTION

; Valid Bits for Flags registry value under [HKEY_LOCAL_MACHINE\init\BootVars]
; 0x00000001    Start storage manager in boot phase 1 for hive-based registry
; 0x00000002    Start device manager in boot phase 1 for hive-based registry

IF PRJ_ENABLE_FSMOUNTASROOT
; HIVE BOOT SECTION
IF PRJ_BOOTDEVICE_ATAPI
[HKEY_LOCAL_MACHINE\init\BootVars]
   "Flags"=dword:3
[HKEY_LOCAL_MACHINE\System\StorageManager\Profiles\HDProfile]
    "MountAsRoot"=dword:1
IF PRJ_ENABLE_FSEXTREPL
; @CESYSGEN IF CE_MODULES_FSREPLXFILT
; @CESYSGEN ELSE
#error PRJ_ENABLE_FSEXTREPL defined without including replication filter component.  Add SYSGEN_FSREPLXFILT to your configuration.
; @CESYSGEN ENDIF CE_MODULES_FSREPLXFILT
ENDIF
ENDIF

